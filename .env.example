# Sentry DSN — get this from your Sentry project settings
# (Settings > Projects > <project> > Client Keys (DSN))
SENTRY_DSN=https://your-key@o123456.ingest.us.sentry.io/1234567

# App port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=development

# Devin API token — used by the Sentry webhook to trigger Devin sessions
# Get this from https://app.devin.ai/settings/api
DEVIN_API_TOKEN=your-devin-api-token-here
